import React, { useState } from "react";

export default function YijingApp() {
  const hexagrams = {
    "111111": {
      name: "乾卦",
      guaci: "元亨利贞。",
      tuan: "大哉乾元，万物资始，乃统天。",
      yaoci: [
        "初九：潜龙勿用。",
        "九二：见龙在田，利见大人。",
        "九三：君子终日乾乾，夕惕若，厉无咎。",
        "九四：或跃在渊，无咎。",
        "九五：飞龙在天，利见大人。",
        "上九：亢龙有悔。"
      ]
    },
    "000000": {
      name: "坤卦",
      guaci: "元亨，利牝马之贞。",
      tuan: "至哉坤元，万物资生，乃顺承天。",
      yaoci: [
        "初六：履霜，坚冰至。",
        "六二：直方大，不习无不利。",
        "六三：含章可贞。或从王事，无成有终。",
        "六四：括囊，无咎无誉。",
        "六五：黄裳，元吉。",
        "上六：龙战于野，其血玄黄。"
      ]
    }
  };

  const defaultHexagram = [1, 1, 1, 1, 1, 1];

  const [lines, setLines] = useState(defaultHexagram);

  const toggleLine = (index) => {
    const newLines = [...lines];
    newLines[index] = newLines[index] === 1 ? 0 : 1;
    setLines(newLines);
  };

  const hexKey = lines.join("");

  const hex =
    hexagrams[hexKey] || {
      name: "未录入卦象",
      guaci: "请继续补全64卦数据。",
      tuan: "暂无彖传。",
      yaoci: [
        "暂无爻辞",
        "暂无爻辞",
        "暂无爻辞",
        "暂无爻辞",
        "暂无爻辞",
        "暂无爻辞"
      ]
    };

  const renderLine = (line, index) => {
    return (
      <div
        key={index}
        onClick={() => toggleLine(index)}
        className="cursor-pointer flex justify-center items-center my-4 transition-transform hover:scale-105"
      >
        {line === 1 ? (
          <div className="w-64 h-8 bg-red-700 rounded-full shadow-lg"></div>
        ) : (
          <div className="flex gap-6">
            <div className="w-28 h-8 bg-red-700 rounded-full shadow-lg"></div>
            <div className="w-28 h-8 bg-red-700 rounded-full shadow-lg"></div>
          </div>
        )}
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-gradient-to-b from-yellow-50 to-orange-100 p-6 text-gray-900">
      <div className="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
        <div className="bg-white rounded-3xl shadow-2xl p-8 border border-red-100">
          <h1 className="text-4xl font-bold mb-6 text-center text-red-700 tracking-widest">
            易经64卦互动程序
          </h1>

          <p className="mb-6 text-center text-gray-600 text-lg">
            点击任意一爻，可阴阳变化生成新卦
          </p>

          <div className="flex flex-col-reverse items-center py-8">
            {lines.map((line, index) => renderLine(line, index))}
          </div>

          <div className="mt-8 text-center">
            <button
              onClick={() => setLines(defaultHexagram)}
              className="px-6 py-3 rounded-2xl bg-red-700 text-white hover:bg-red-800 transition text-lg shadow-lg"
            >
              恢复乾卦
            </button>
          </div>
        </div>

        <div className="bg-white rounded-3xl shadow-2xl p-8 overflow-auto border border-red-100">
          <h2 className="text-4xl font-bold mb-6 text-red-700 tracking-widest">
            {hex.name}
          </h2>

          <div className="mb-8">
            <h3 className="text-2xl font-semibold mb-3 text-red-600">卦辞</h3>
            <p className="leading-10 text-xl">{hex.guaci}</p>
          </div>

          <div className="mb-8">
            <h3 className="text-2xl font-semibold mb-3 text-red-600">彖传</h3>
            <p className="leading-10 text-xl">{hex.tuan}</p>
          </div>

          <div>
            <h3 className="text-2xl font-semibold mb-4 text-red-600">爻辞</h3>
            <div className="space-y-4">
              {hex.yaoci.map((item, idx) => (
                <div
                  key={idx}
                  className="border border-red-100 rounded-2xl p-4 bg-red-50 text-lg leading-8"
                >
                  {item}
                </div>
              ))}
            </div>
          </div>

          <div className="mt-10 text-base text-gray-500 leading-8">
            当前仅示例录入乾卦与坤卦。<br />
            你可以继续扩展 hexagrams 对象，补全64卦数据。<br />
            阳爻 = 1，阴爻 = 0。<br />
            例如：乾卦 = 111111，坤卦 = 000000。
          </div>
        </div>
      </div>
    </div>
  );
}
